package com.lizongying.mytv

import android.content.Context
import android.util.Log
import androidx.test.core.app.ApplicationProvider
import org.junit.Test
import org.junit.runner.RunWith
import org.robolectric.RobolectricTestRunner
import org.robolectric.annotation.Config

/**
 * 播放器集成测试
 * 测试统一播放器架构的各个组件
 */
@RunWith(RobolectricTestRunner::class)
@Config(sdk = [34])
class PlayerIntegrationTest {
    
    private val context: Context = ApplicationProvider.getApplicationContext()
    
    companion object {
        private const val TAG = "PlayerIntegrationTest"
        
        // 测试URLs
        private val TEST_URLS = listOf(
            // RTP流
            "rtp://239.1.1.1:5000" to "RTP组播流",
            "udp://192.168.1.100:1234" to "UDP单播流",
            "rtp://224.0.0.1:5004" to "RTP组播地址",
            
            // RTSP流
            "rtsp://example.com/live/stream" to "RTSP流",
            "rtsp://192.168.1.101:554/stream" to "RTSP带端口",
            
            // HTTP/HLS流
            "http://example.com/stream.m3u8" to "HLS流",
            "https://example.com/stream.m3u8" to "HTTPS HLS流",
            "http://example.com/video.mp4" to "HTTP MP4流",
            
            // 其他协议
            "rtmp://example.com/live/stream" to "RTMP流"
        )
    }
    
    /**
     * 测试播放器工厂协议检测
     */
    @Test
    fun testPlayerFactoryProtocolDetection() {
        Log.d(TAG, "=== 测试播放器工厂协议检测 ===")
        
        TEST_URLS.forEach { (url, description) ->
            val playerType = PlayerFactory.detectPlayerType(url)
            val protocolDesc = PlayerFactory.getProtocolDescription(url)
            val isSupported = PlayerFactory.isUrlSupported(url)
            
            Log.d(TAG, "URL: $url")
            Log.d(TAG, "描述: $description")
            Log.d(TAG, "检测到的播放器类型: $playerType")
            Log.d(TAG, "协议描述: $protocolDesc")
            Log.d(TAG, "是否支持: $isSupported")
            Log.d(TAG, "---")
            
            // 验证检测逻辑
            when {
                url.startsWith("rtp://", ignoreCase = true) ||
                url.startsWith("udp://", ignoreCase = true) ||
                url.startsWith("rtp:", ignoreCase = true) ||
                url.startsWith("udp:", ignoreCase = true) -> {
                    assert(playerType == UnifiedVideoPlayer.PlayerType.VLC_PLAYER) {
                        "RTP/UDP流应该使用VLC播放器: $url"
                    }
                }
                url.startsWith("rtsp://", ignoreCase = true) -> {
                    assert(playerType == UnifiedVideoPlayer.PlayerType.VLC_PLAYER) {
                        "RTSP流应该使用VLC播放器: $url"
                    }
                }
                url.startsWith("http://", ignoreCase = true) ||
                url.startsWith("https://", ignoreCase = true) ||
                url.contains(".m3u8", ignoreCase = true) -> {
                    assert(playerType == UnifiedVideoPlayer.PlayerType.EXO_PLAYER) {
                        "HTTP/HLS流应该使用ExoPlayer: $url"
                    }
                }
            }
        }
        
        Log.d(TAG, "协议检测测试通过 ✓")
    }
    
    /**
     * 测试RTP协议检测器
     */
    @Test
    fun testRTPProtocolDetector() {
        Log.d(TAG, "=== 测试RTP协议检测器 ===")
        
        val rtpUrls = listOf(
            "rtp://239.1.1.1:5000",
            "udp://192.168.1.100:1234",
            "rtsp://example.com:554/stream"
        )
        
        rtpUrls.forEach { url ->
            val isRTP = RTPProtocolDetector.isRTPStream(url)
            val isRTSP = RTPProtocolDetector.isRTSPStream(url)
            val isMulticast = RTPProtocolDetector.isMulticastStream(url)
            val host = RTPProtocolDetector.extractHostFromUrl(url)
            val port = RTPProtocolDetector.extractPortFromUrl(url)
            val details = RTPProtocolDetector.getStreamProtocolDetails(url)
            val validation = RTPProtocolDetector.validateRTPUrl(url)
            val suggestions = RTPProtocolDetector.getRTPPlaybackSuggestions(url)
            
            Log.d(TAG, "URL: $url")
            Log.d(TAG, "是RTP流: $isRTP")
            Log.d(TAG, "是RTSP流: $isRTSP")
            Log.d(TAG, "是组播流: $isMulticast")
            Log.d(TAG, "主机: $host")
            Log.d(TAG, "端口: $port")
            Log.d(TAG, "协议类型: ${details.protocolType}")
            Log.d(TAG, "推荐播放器: ${details.recommendedPlayer}")
            Log.d(TAG, "验证结果: ${validation.isValid} - ${validation.message}")
            Log.d(TAG, "建议:")
            suggestions.forEach { suggestion -> Log.d(TAG, "  - $suggestion") }
            Log.d(TAG, "---")
            
            // 验证组播地址检测
            if (host.startsWith("239.") || host.startsWith("224.")) {
                assert(isMulticast) { "组播地址应该被检测为组播流: $host" }
            }
        }
        
        Log.d(TAG, "RTP协议检测器测试通过 ✓")
    }
    
    /**
     * 测试播放器创建和初始化
     */
    @Test
    fun testPlayerCreation() {
        Log.d(TAG, "=== 测试播放器创建和初始化 ===")
        
        // 测试VLC播放器创建
        Log.d(TAG, "测试VLC播放器创建...")
        val vlcPlayer = VLCPlayerWrapper()
        val vlcInitialized = vlcPlayer.initialize(context)
        assert(vlcInitialized) { "VLC播放器应该初始化成功" }
        assert(vlcPlayer.getPlayerType() == UnifiedVideoPlayer.PlayerType.VLC_PLAYER) {
            "播放器类型应该是VLC_PLAYER"
        }
        vlcPlayer.release()
        Log.d(TAG, "VLC播放器创建测试通过 ✓")
        
        // 测试ExoPlayer创建
        Log.d(TAG, "测试ExoPlayer创建...")
        val exoPlayer = ExoPlayerWrapper()
        val exoInitialized = exoPlayer.initialize(context)
        assert(exoInitialized) { "ExoPlayer应该初始化成功" }
        assert(exoPlayer.getPlayerType() == UnifiedVideoPlayer.PlayerType.EXO_PLAYER) {
            "播放器类型应该是EXO_PLAYER"
        }
        exoPlayer.release()
        Log.d(TAG, "ExoPlayer创建测试通过 ✓")
        
        // 测试播放器工厂创建
        Log.d(TAG, "测试播放器工厂创建...")
        val testUrls = listOf(
            "rtp://239.1.1.1:5000" to UnifiedVideoPlayer.PlayerType.VLC_PLAYER,
            "http://example.com/stream.m3u8" to UnifiedVideoPlayer.PlayerType.EXO_PLAYER
        )
        
        testUrls.forEach { (url, expectedType) ->
            val player = PlayerFactory.createPlayer(context, url)
            assert(player.getPlayerType() == expectedType) {
                "URL $url 应该创建 $expectedType 播放器，但得到 ${player.getPlayerType()}"
            }
            player.release()
        }
        Log.d(TAG, "播放器工厂创建测试通过 ✓")
    }
    
    /**
     * 测试协议支持检查
     */
    @Test
    fun testProtocolSupport() {
        Log.d(TAG, "=== 测试协议支持检查 ===")
        
        // 测试VLC播放器协议支持
        val vlcPlayer = VLCPlayerWrapper()
        vlcPlayer.initialize(context)
        
        val vlcSupportedUrls = listOf(
            "rtp://239.1.1.1:5000",
            "udp://192.168.1.100:1234",
            "rtsp://example.com/live/stream",
            "rtmp://example.com/live/stream"
        )
        
        val vlcUnsupportedUrls = listOf(
            "http://example.com/stream.m3u8",
            "https://example.com/video.mp4"
        )
        
        vlcSupportedUrls.forEach { url ->
            assert(vlcPlayer.supportsProtocol(url)) {
                "VLC应该支持协议: $url"
            }
        }
        
        vlcUnsupportedUrls.forEach { url ->
            // VLC实际上支持HTTP，但我们的实现中标记为不支持
            // 这里根据实际实现调整断言
            Log.d(TAG, "VLC对 $url 的支持: ${vlcPlayer.supportsProtocol(url)}")
        }
        
        vlcPlayer.release()
        
        // 测试ExoPlayer协议支持
        val exoPlayer = ExoPlayerWrapper()
        exoPlayer.initialize(context)
        
        val exoSupportedUrls = listOf(
            "http://example.com/stream.m3u8",
            "https://example.com/video.mp4",
            "http://example.com/stream.mpd"
        )
        
        exoSupportedUrls.forEach { url ->
            assert(exoPlayer.supportsProtocol(url)) {
                "ExoPlayer应该支持协议: $url"
            }
        }
        
        exoPlayer.release()
        
        Log.d(TAG, "协议支持检查测试通过 ✓")
    }
    
    /**
     * 测试混合播放场景
     */
    @Test
    fun testHybridPlaybackScenario() {
        Log.d(TAG, "=== 测试混合播放场景 ===")
        
        // 模拟不同协议的播放场景
        val scenarios = listOf(
            Scenario(
                name = "RTP组播电视流",
                url = "rtp://239.1.1.1:5000",
                expectedPlayer = UnifiedVideoPlayer.PlayerType.VLC_PLAYER,
                expectedProtocol = "RTP/UDP流"
            ),
            Scenario(
                name = "HLS在线直播",
                url = "http://example.com/live/stream.m3u8",
                expectedPlayer = UnifiedVideoPlayer.PlayerType.EXO_PLAYER,
                expectedProtocol = "HLS流"
            ),
            Scenario(
                name = "RTSP监控摄像头",
                url = "rtsp://192.168.1.100:554/stream",
                expectedPlayer = UnifiedVideoPlayer.PlayerType.VLC_PLAYER,
                expectedProtocol = "RTSP流"
            ),
            Scenario(
                name = "HTTP点播视频",
                url = "http://example.com/video.mp4",
                expectedPlayer = UnifiedVideoPlayer.PlayerType.EXO_PLAYER,
                expectedProtocol = "HTTP流"
            )
        )
        
        scenarios.forEach { scenario ->
            Log.d(TAG, "测试场景: ${scenario.name}")
            Log.d(TAG, "URL: ${scenario.url}")
            
            // 检测播放器类型
            val detectedPlayer = PlayerFactory.detectPlayerType(scenario.url)
            assert(detectedPlayer == scenario.expectedPlayer) {
                "${scenario.name}: 应该检测到 ${scenario.expectedPlayer}，但得到 $detectedPlayer"
            }
            
            // 检测协议类型
            val protocolDesc = PlayerFactory.getProtocolDescription(scenario.url)
            Log.d(TAG, "检测到的协议: $protocolDesc")
            
            // 创建播放器
            val player = PlayerFactory.createPlayer(context, scenario.url)
            assert(player.getPlayerType() == scenario.expectedPlayer) {
                "${scenario.name}: 应该创建 ${scenario.expectedPlayer} 播放器"
            }
            
            // 验证协议支持
            assert(player.supportsProtocol(scenario.url)) {
                "${scenario.name}: 播放器应该支持协议 ${scenario.url}"
            }
            
            player.release()
            Log.d(TAG, "场景测试通过: ${scenario.name} ✓")
            Log.d(TAG, "---")
        }
        
        Log.d(TAG, "所有混合播放场景测试通过 ✓")
    }
    
    /**
     * 运行所有测试
     */
    @Test
    fun runAllTests() {
        Log.d(TAG, "开始运行所有播放器集成测试")
        
        testPlayerFactoryProtocolDetection()
        testRTPProtocolDetector()
        testPlayerCreation()
        testProtocolSupport()
        testHybridPlaybackScenario()
        
        Log.d(TAG, "所有播放器集成测试完成 ✓")
        Log.d(TAG, "统一播放器架构验证通过")
        Log.d(TAG, "VLC集成 - 阶段二：架构设计和主播放器集成完成")
    }
    
    /**
     * 测试场景数据类
     */
    data class Scenario(
        val name: String,
        val url: String,
        val expectedPlayer: UnifiedVideoPlayer.PlayerType,
        val expectedProtocol: String
    )
}