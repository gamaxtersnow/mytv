<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/iptv_row_height"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <TextView
        android:id="@+id/channel_number"
        android:layout_width="48dp"
        android:layout_height="52dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:singleLine="true"
        android:textColor="@color/channel_panel_text_secondary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/channel_logo"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="10dp"
        android:contentDescription="@string/channel_panel_logo"
        android:scaleType="centerInside" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/channel_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/channel_panel_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/channel_program"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/channel_panel_text_secondary"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/channel_program_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progressDrawable="@drawable/iptv_progress"
            android:visibility="gone" />

        <TextView
            android:id="@+id/channel_next_program"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/channel_panel_text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/playing_marker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="10dp"
        android:text="@string/channel_panel_playing"
        android:textColor="@color/channel_panel_accent"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
