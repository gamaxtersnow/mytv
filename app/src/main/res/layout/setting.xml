<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <FrameLayout
        android:layout_width="420dp"
        android:layout_height="320dp"
        android:background="@drawable/setting_dialog_bg"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- 左侧导航 -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="设置"
                    android:textColor="#FFEEEEEE"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nav_source"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/setting_nav_item_bg"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="播放源"
                    android:textColor="#FFEEEEEE"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/nav_playback"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/setting_nav_item_bg"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="播放设置"
                    android:textColor="#FFEEEEEE"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/nav_display"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/setting_nav_item_bg"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="显示设置"
                    android:textColor="#FFEEEEEE"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/nav_system"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/setting_nav_item_bg"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="系统设置"
                    android:textColor="#FFEEEEEE"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 右侧内容区 -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <!-- 播放源面板 -->
                <LinearLayout
                    android:id="@+id/panel_source"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="播放源设置"
                        android:textColor="#FF0096A6"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="远程播放列表 URL"
                        android:textColor="#B3EEEEEE"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/remote_url"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="6dp"
                        android:background="#FF1C262B"
                        android:hint="输入 M3U8 链接"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="#FFEEEEEE"
                        android:textColorHint="#80EEEEEE"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/update_now"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:background="#FF0096A6"
                            android:focusable="true"
                            android:text="立即更新"
                            android:textColor="#FFEEEEEE"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/update_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="12dp"
                            android:textColor="#B3EEEEEE"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 播放设置面板 -->
                <LinearLayout
                    android:id="@+id/panel_playback"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="播放设置"
                        android:textColor="#FF0096A6"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/setting_item_bg"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="换台反转"
                            android:textColor="#FFEEEEEE"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switch_channel_reversal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/setting_item_bg"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="换台时显示频道号"
                            android:textColor="#FFEEEEEE"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switch_channel_num"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 显示设置面板 -->
                <LinearLayout
                    android:id="@+id/panel_display"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="显示设置"
                        android:textColor="#FF0096A6"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/setting_item_bg"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="显示时间"
                            android:textColor="#FFEEEEEE"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switch_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 系统设置面板 -->
                <LinearLayout
                    android:id="@+id/panel_system"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="系统设置"
                        android:textColor="#FF0096A6"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/setting_item_bg"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="开机自启"
                            android:textColor="#FFEEEEEE"
                            android:textSize="14sp" />

                        <Switch
                            android:id="@+id/switch_boot_startup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:focusable="true" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/exit"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="20dp"
                        android:background="#FFE53935"
                        android:focusable="true"
                        android:text="退出应用"
                        android:textColor="#FFEEEEEE"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>