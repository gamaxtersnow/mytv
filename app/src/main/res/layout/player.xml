<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:keepScreenOn="true">

    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:resize_mode="fill"
        app:use_controller="false" />

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:resize_mode="fill"
        app:use_controller="false" />

    <!-- 播放器状态和性能监控覆盖层 -->
    <include
        android:id="@+id/player_status_container"
        layout="@layout/player_status_overlay" />

    <!-- 播放器控制面板 -->
    <include
        android:id="@+id/player_control_container"
        layout="@layout/player_control_panel" />

    <!-- 性能监控面板 -->
    <include
        android:id="@+id/performance_monitor_container"
        layout="@layout/performance_monitor_panel" />
</FrameLayout>