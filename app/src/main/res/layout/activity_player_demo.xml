<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="播放器架构演示"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:textColor="@color/primary" />

        <!-- 架构描述 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="统一播放器架构 v1.0\n支持自动协议识别和播放器选择"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:textColor="@color/secondary" />

        <!-- 协议信息区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="协议信息:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/protocolInfoTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@color/surface"
            android:padding="12dp"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"
            android:text="等待协议检测..."
            android:textColor="@color/on_surface" />

        <!-- 控制按钮 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="功能演示:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDetectProtocols"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="演示协议检测"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCreatePlayers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="演示播放器创建"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnHybridScenarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="演示混合播放场景"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTestRTPDetector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="测试RTP协议检测器"
            android:layout_marginBottom="16dp" />

        <!-- 日志区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="操作日志:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/logTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:padding="12dp"
                android:textSize="12sp"
                android:text="日志区域\n"
                android:textColor="@color/on_surface"
                android:fontFamily="monospace" />
        </ScrollView>

        <!-- 控制按钮 -->
        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="清理日志"
            android:layout_marginBottom="24dp" />

        <!-- 架构总结 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="架构特点:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• 统一播放器接口 (UnifiedVideoPlayer)\n• 智能播放器工厂 (PlayerFactory)\n• 自动协议识别 (RTP/RTSP/HTTP/HLS)\n• GSYVideoPlayer包装 (RTP/UDP支持)\n• ExoPlayer包装 (HTTP/HLS支持)\n• 向后兼容现有功能"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/on_surface" />

    </LinearLayout>
</ScrollView>